.mf input.ro{color:var(--tx2);background:var(--bg4)}
.mhint{font-size:12px;color:var(--tx2);padding:10px 13px;background:var(--bg3);border-radius:var(--r);line-height:1.8;border-left:2px solid var(--gr)}
