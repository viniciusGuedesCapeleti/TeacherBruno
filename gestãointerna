<script>
// ═══════════════════════════════════════════════════════
//  TOUR SYSTEM
// ═══════════════════════════════════════════════════════
const STEPS = [
  {
    target: 'sal-badge-el',
    emoji: '💰',
    title: 'Filtro salarial configurável',
    desc: 'O sistema filtra automaticamente vagas dentro da faixa de salário que você definir. Vagas fora do intervalo são ocultadas sem você precisar fazer nada.',
    highlight: '<strong>Neste demo:</strong> R$ 3.500 – R$ 7.000. Na versão real você define qualquer faixa que quiser.',
    pos: 'bottom'
  },
  {
    target: 'stats-section',
    emoji: '📊',
    title: 'Painel de estatísticas',
    desc: 'Mostra em tempo real quantas vagas estão disponíveis agora, separadas por área. Os números atualizam automaticamente quando você aplica filtros.',
    highlight: '<strong>Total</strong> = todas as vagas ativas · <strong>MKT</strong> = Marketing · <strong>Social</strong> = Social Media · <strong>Design</strong> · <strong>TI</strong>',
    pos: 'bottom'
  },
  {
    target: 'srcs-section',
    emoji: '🌐',
    title: 'Fontes monitoradas',
    desc: 'O sistema agrega vagas de 6 plataformas diferentes ao mesmo tempo. Cada fonte tem uma cor própria — a borda lateral de cada vaga indica de qual plataforma ela veio.',
    highlight: '🟢 Indeed · 🔵 LinkedIn · 🟣 Gupy · 🟡 Catho · 🟠 Jobbol · 🩷 Emprega Campinas',
    pos: 'bottom'
  },
  {
    target: 'progress-section',
    emoji: '⭐',
    title: 'Rastreador de progresso',
    desc: 'Acompanhe sua jornada de candidatura. Salve vagas de interesse com ⭐ e o sistema registra quantos emails você já enviou.',
    highlight: '<strong>Salvas</strong> = vagas que você marcou para candidatar · <strong>Enviadas</strong> = emails disparados via Gmail',
    pos: 'bottom'
  },
  {
    target: 'search-section',
    emoji: '🔍',
    title: 'Busca inteligente',
    desc: 'Digite qualquer palavra e o sistema filtra por cargo, empresa ou descrição da vaga instantaneamente. Ao lado, ordene por mais recentes, maior salário ou empresa A–Z.',
    highlight: 'Tente buscar: <strong>"pleno"</strong>, <strong>"remoto"</strong> ou <strong>"design"</strong>',
    pos: 'bottom'
  },
  {
    target: 'filter-area',
    emoji: '🏷️',
    title: 'Filtros por área e nível',
    desc: 'Filtre vagas por área de atuação (Marketing, Social Media, Design ou TI) e por nível de senioridade (Júnior, Pleno, Sênior ou Coordenador). Os filtros combinam entre si.',
    highlight: 'Exemplo: <strong>Social + Pleno + Remoto</strong> mostra só vagas de Social Media Pleno em modo remoto.',
    pos: 'bottom'
  },
  {
    target: 'filter-fonte',
    emoji: '📡',
    title: 'Filtro por fonte',
    desc: 'Prefere vagas só do LinkedIn? Ou só do Indeed? Filtre por plataforma com um toque. Útil para focar em fontes que têm mais vagas da sua área.',
    highlight: 'Todas as fontes são monitoradas ao mesmo tempo — o filtro apenas exibe as que você quer ver.',
    pos: 'top'
  },
  {
    target: 'refresh-section',
    emoji: '⏱️',
    title: 'Auto-refresh e contagem regressiva',
    desc: 'A barra de progresso mostra o tempo até a próxima atualização automática — a cada 5 minutos o sistema busca vagas novas. Você também pode atualizar manualmente a qualquer momento.',
    highlight: '<strong>Vagas com mais de 3 dias são removidas automaticamente</strong> — a lista sempre fica limpa com apenas oportunidades recentes.',
    pos: 'top'
  },
  {
    target: 'jlist',
    emoji: '📋',
    title: 'Cards de vaga — tudo em um lugar',
    desc: 'Cada card mostra: título, empresa, descrição, salário, modalidade, fonte e tempo de publicação. A barra colorida embaixo indica quanto tempo a vaga ainda tem antes de expirar.',
    highlight: '🟢 Verde = menos de 24h · 🟡 Amarelo = 1 a 2 dias · 🔴 Vermelho = prestes a expirar · <strong>Botão ✉ Email abre o Gmail com tudo preenchido!</strong>',
    pos: 'top'
  },
];

let currentStep = 0;
let tourActive = false;

function startTour() {
  // Fecha welcome se estiver aberto
  document.getElementById('welcome').classList.add('hide');
  setTimeout(() => {
    document.getElementById('welcome').style.display = 'none';
  }, 400);

  tourActive = true;
  currentStep = 0;
  document.getElementById('tourBackdrop').classList.add('active');
  document.getElementById('tourBtnFloat').classList.add('hidden');

  // Cria dots
  const dotsEl = document.getElementById('tipDots');
  dotsEl.innerHTML = STEPS.map((_,i) => `<span class="tip-dot" id="dot-${i}"></span>`).join('');

  showStep(0);
}

function skipTour() {
  document.getElementById('welcome').classList.add('hide');
  setTimeout(() => {
    document.getElementById('welcome').style.display = 'none';
    document.getElementById('tourBtnFloat').classList.remove('hidden');
  }, 400);
}

function showStep(idx) {
  const step = STEPS[idx];
  const target = document.getElementById(step.target);

  if (!target) { nextStep(); return; }

  // Scroll to element
  target.scrollIntoView({ behavior: 'smooth', block: 'center' });

  setTimeout(() => {
    const rect = target.getBoundingClientRect();
    const pad = 8;

    // Posiciona spotlight
    const spot = document.getElementById('tourSpotlight');
    spot.style.display = 'block';
    spot.style.top = (rect.top + window.scrollY - pad) + 'px';
    spot.style.left = (rect.left - pad) + 'px';
    spot.style.width = (rect.width + pad * 2) + 'px';
    spot.style.height = (rect.height + pad * 2) + 'px';

    // Posiciona tooltip
    const tip = document.getElementById('tourTip');
    tip.style.display = 'block';
    tip.className = 'tour-tip';

    const tipW = Math.min(300, window.innerWidth - 40);
    let tipLeft = rect.left;
    let tipTop;

    if (step.pos === 'bottom') {
      tipTop = rect.bottom + window.scrollY + pad + 12;
      tip.classList.add('tip-bottom');
    } else {
      tipTop = rect.top + window.scrollY - 20 - 300;
      tip.classList.add('tip-top');
    }

    // Garante que não sai da tela
    tipLeft = Math.max(16, Math.min(tipLeft, window.innerWidth - tipW - 16));
    if (tipTop < window.scrollY + 10) tipTop = rect.bottom + window.scrollY + 12;

    tip.style.top = tipTop + 'px';
    tip.style.left = tipLeft + 'px';
    tip.style.width = tipW + 'px';

    // Conteúdo
    document.getElementById('tipEmoji').textContent = step.emoji;
    document.getElementById('tipTitle').textContent = step.title;
    document.getElementById('tipDesc').textContent = step.desc;
    document.getElementById('tipStepLabel').textContent = `Passo ${idx + 1} de ${STEPS.length}`;

    const hl = document.getElementById('tipHighlight');
    if (step.highlight) {
      hl.style.display = 'block';
      hl.innerHTML = step.highlight;
    } else {
      hl.style.display = 'none';
    }

    // Dots
    document.querySelectorAll('.tip-dot').forEach((d, i) => {
      d.classList.toggle('on', i === idx);
    });

    // Botões
    const prev = document.getElementById('tipPrev');
    const next = document.getElementById('tipNext');
    prev.style.display = idx === 0 ? 'none' : 'block';

    if (idx === STEPS.length - 1) {
      next.outerHTML = `<button class="tip-finish" id="tipNext" onclick="endTour()">✅ Concluir tour</button>`;
    } else {
      if (next.className === 'tip-finish') {
        next.outerHTML = `<button class="tip-next" id="tipNext" onclick="nextStep()">Próximo →</button>`;
      }
    }

    // Scroll para o tooltip
    setTimeout(() => {
      tip.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }, 200);

  }, 400);
}

function nextStep() {
  if (currentStep < STEPS.length - 1) {
    currentStep++;
    showStep(currentStep);
  }
}
function prevStep() {
  if (currentStep > 0) {
    currentStep--;
    showStep(currentStep);
  }
}
function endTour() {
  tourActive = false;
  document.getElementById('tourBackdrop').classList.remove('active');
  document.getElementById('tourSpotlight').style.display = 'none';
  document.getElementById('tourTip').style.display = 'none';
  document.getElementById('tourBtnFloat').classList.remove('hidden');
  showToast('Tour concluído! Explore o sistema à vontade 🎉');
}

// Fechar ao clicar no backdrop
document.getElementById('tourBackdrop').addEventListener('click', endTour);

