.foot{border-top:0.5px solid var(--b1);padding:16px;max-width:960px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:6px}
.foot span{font-size:10px;color:var(--tx3)}
