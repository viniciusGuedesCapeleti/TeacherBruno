.toast{position:fixed;bottom:calc(80px + var(--safe-b));left:50%;transform:translateX(-50%) translateY(80px);background:var(--bg3);border:0.5px solid var(--ac);border-radius:var(--rl);padding:12px 18px;font-size:13px;color:var(--tx);z-index:400;opacity:0;transition:all .35s cubic-bezier(.34,1.56,.64,1);display:flex;align-items:center;gap:9px;box-shadow:0 12px 40px rgba(0,0,0,.6);max-width:calc(100vw - 32px)}
.toast.show{transform:translateX(-50%) translateY(0);opacity:1}
.tdot{width:8px;height:8px;border-radius:50%;background:var(--gr);flex-shrink:0}

