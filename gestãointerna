<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="theme-color" content="#08080E">
<title>VagaRadar — Demo | Tour Guiado</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#08080E;--bg2:#0F0F17;--bg3:#14141E;--bg4:#1A1A26;
  --b1:rgba(255,255,255,0.06);--b2:rgba(255,255,255,0.11);--b3:rgba(255,255,255,0.18);
  --ac:#7C6FFF;--ac2:#A594FF;--glow:rgba(124,111,255,0.2);
  --gr:#1FD189;--grbg:rgba(31,209,137,0.1);--grb:rgba(31,209,137,0.25);
  --pk:#FF6B9D;--pkbg:rgba(255,107,157,0.1);
  --am:#FFB547;--ambg:rgba(255,181,71,0.1);
  --bl:#4FC3F7;--blbg:rgba(79,195,247,0.1);
  --or:#FF7043;--orbg:rgba(255,112,67,0.1);
  --tx:#EEEEF8;--tx2:#8888A8;--tx3:#50506A;
  --r:10px;--rl:14px;--rx:18px;
  --fd:'Space Grotesk',sans-serif;--fb:'Inter',sans-serif;
  --safe-b:env(safe-area-inset-bottom,0px);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html{scroll-behavior:smooth;-webkit-text-size-adjust:100%}
body{background:var(--bg);color:var(--tx);font-family:var(--fb);font-size:14px;line-height:1.6;overflow-x:hidden}
::-webkit-scrollbar{width:4px}::-webkit-scrollbar-thumb{background:var(--bg4);border-radius:2px}
button,input,select,textarea{-webkit-appearance:none;appearance:none;font-family:var(--fb)}

/* ══════════════════════════════════════════
   TOUR SYSTEM
══════════════════════════════════════════ */

/* WELCOME SCREEN */
.welcome{position:fixed;inset:0;z-index:9999;background:var(--bg);display:flex;align-items:center;justify-content:center;padding:24px;transition:opacity .4s,transform .4s}
.welcome.hide{opacity:0;pointer-events:none;transform:scale(.97)}
.welcome-card{background:var(--bg2);border:0.5px solid var(--b2);border-radius:var(--rx);padding:32px 24px;max-width:420px;width:100%;text-align:center;position:relative;overflow:hidden}
.welcome-card::before{content:'';position:absolute;top:-60px;left:50%;transform:translateX(-50%);width:300px;height:220px;background:radial-gradient(ellipse,rgba(124,111,255,0.2),transparent 70%);pointer-events:none}
.welcome-logo{width:64px;height:64px;background:linear-gradient(135deg,var(--ac),var(--ac2));border-radius:20px;display:flex;align-items:center;justify-content:center;font-size:28px;margin:0 auto 20px;box-shadow:0 8px 32px var(--glow)}
.welcome-title{font-family:var(--fd);font-size:24px;font-weight:700;letter-spacing:-.02em;margin-bottom:8px}
.welcome-grad{background:linear-gradient(135deg,var(--ac),var(--ac2) 45%,var(--pk));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.welcome-sub{font-size:13px;color:var(--tx2);line-height:1.7;margin-bottom:24px}
.welcome-features{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:24px;text-align:left}
.wf{background:var(--bg3);border:0.5px solid var(--b1);border-radius:var(--r);padding:10px 12px;display:flex;align-items:center;gap:8px}
.wf-icon{font-size:18px;flex-shrink:0}
.wf-text{font-size:11px;color:var(--tx2);line-height:1.4}
.wf-title{font-size:11px;font-weight:600;color:var(--tx);display:block;margin-bottom:1px}
.btn-tour{width:100%;padding:14px;border-radius:var(--r);border:none;background:linear-gradient(135deg,var(--ac),var(--ac2));color:#fff;font-family:var(--fd);font-size:15px;font-weight:700;cursor:pointer;box-shadow:0 4px 20px var(--glow);display:flex;align-items:center;justify-content:center;gap:8px;margin-bottom:10px;transition:opacity .15s}
.btn-tour:active{opacity:.88}
.btn-skip{width:100%;padding:10px;border-radius:var(--r);border:0.5px solid var(--b2);background:transparent;color:var(--tx3);font-size:13px;cursor:pointer;transition:all .15s}
.btn-skip:active{color:var(--tx2)}

/* TOUR OVERLAY */
.tour-overlay{position:fixed;inset:0;z-index:8000;pointer-events:none}
.tour-backdrop{position:absolute;inset:0;background:rgba(0,0,0,0);transition:background .3s}
.tour-backdrop.active{background:rgba(0,0,0,0.75);pointer-events:all}

/* TOUR SPOTLIGHT */
.tour-spotlight{position:absolute;border-radius:var(--rl);box-shadow:0 0 0 9999px rgba(0,0,0,0.78);transition:all .4s cubic-bezier(.4,0,.2,1);pointer-events:none;border:2px solid var(--ac);animation:spotlight-pulse 2s infinite}
@keyframes spotlight-pulse{0%,100%{box-shadow:0 0 0 9999px rgba(0,0,0,0.78),0 0 0 0 rgba(124,111,255,.4)}50%{box-shadow:0 0 0 9999px rgba(0,0,0,0.78),0 0 0 8px rgba(124,111,255,0)}}

/* TOUR TOOLTIP */
.tour-tip{position:absolute;background:var(--bg2);border:0.5px solid rgba(124,111,255,0.4);border-radius:var(--rx);padding:18px 18px 16px;max-width:300px;width:calc(100vw - 40px);z-index:8001;pointer-events:all;box-shadow:0 16px 48px rgba(0,0,0,.7);transition:all .35s cubic-bezier(.4,0,.2,1)}
.tour-tip::before{content:'';position:absolute;width:10px;height:10px;background:var(--bg2);border:0.5px solid rgba(124,111,255,0.4);transform:rotate(45deg)}
.tour-tip.tip-bottom::before{top:-6px;left:24px;border-bottom:none;border-right:none}
.tour-tip.tip-top::before{bottom:-6px;left:24px;border-top:none;border-left:none}
.tour-tip.tip-left::before{right:-6px;top:20px;border-left:none;border-bottom:none}

.tip-step{font-size:10px;font-weight:600;color:var(--ac2);text-transform:uppercase;letter-spacing:.06em;margin-bottom:6px;display:flex;align-items:center;gap:6px}
.tip-step-dots{display:flex;gap:4px}
.tip-dot{width:6px;height:6px;border-radius:50%;background:var(--b2);transition:background .2s}
.tip-dot.on{background:var(--ac)}
.tip-emoji{font-size:22px;margin-bottom:8px;display:block}
.tip-title{font-family:var(--fd);font-size:15px;font-weight:700;color:var(--tx);margin-bottom:5px}
.tip-desc{font-size:12px;color:var(--tx2);line-height:1.7;margin-bottom:14px}
.tip-highlight{background:rgba(124,111,255,0.1);border:0.5px solid rgba(124,111,255,0.2);border-radius:var(--r);padding:8px 10px;font-size:11px;color:var(--ac2);margin-bottom:14px;line-height:1.6}
.tip-highlight strong{color:var(--ac3)}
.tip-btns{display:flex;gap:7px}
.tip-prev{flex:1;padding:9px;border-radius:var(--r);border:0.5px solid var(--b2);background:transparent;color:var(--tx3);font-size:12px;cursor:pointer;transition:all .15s}
.tip-prev:active{color:var(--tx)}
.tip-next{flex:2;padding:9px;border-radius:var(--r);border:none;background:linear-gradient(135deg,var(--ac),var(--ac2));color:#fff;font-size:12px;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:5px;font-family:var(--fd);transition:opacity .15s}
.tip-next:active{opacity:.88}
.tip-finish{flex:2;padding:9px;border-radius:var(--r);border:none;background:linear-gradient(135deg,var(--gr),#16a865);color:#fff;font-size:12px;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:5px;font-family:var(--fd)}

/* TOUR BUTTON (re-abre tour) */
.tour-btn-float{position:fixed;bottom:calc(24px + var(--safe-b));right:16px;z-index:500;width:44px;height:44px;border-radius:50%;background:linear-gradient(135deg,var(--ac),var(--ac2));border:none;color:#fff;font-size:18px;cursor:pointer;box-shadow:0 4px 20px var(--glow);display:flex;align-items:center;justify-content:center;transition:all .2s}
.tour-btn-float:active{transform:scale(.92)}
.tour-btn-float.hidden{opacity:0;pointer-events:none}

/* ══════════════════════════════════════════
   APP STYLES
══════════════════════════════════════════ */
.demo-banner{background:linear-gradient(135deg,rgba(124,111,255,0.12),rgba(255,107,157,0.08));border-bottom:0.5px solid rgba(124,111,255,0.2);padding:9px 16px;display:flex;align-items:center;justify-content:center;gap:8px;flex-wrap:wrap;text-align:center}
.demo-tag{background:rgba(124,111,255,0.2);border:0.5px solid rgba(124,111,255,0.35);border-radius:99px;padding:3px 10px;font-size:10px;font-weight:700;color:var(--ac2);letter-spacing:.06em;text-transform:uppercase}
.demo-banner span{font-size:11px;color:var(--tx2)}
.demo-banner strong{color:var(--ac2)}

.topbar{position:sticky;top:0;z-index:60;width:100%;height:2px;background:var(--bg4)}
.topbar-fill{height:2px;background:linear-gradient(90deg,var(--ac),var(--pk),var(--gr));transition:width .6s linear}

.hero{position:relative;padding:32px 16px 22px;text-align:center;overflow:hidden}
.hero::before{content:'';position:absolute;top:-60px;left:50%;transform:translateX(-50%);width:min(600px,150vw);height:320px;background:radial-gradient(ellipse,rgba(124,111,255,0.13),transparent 65%);pointer-events:none}
.hero>*{position:relative;z-index:1}
.eyebrow{display:inline-flex;align-items:center;gap:7px;background:rgba(124,111,255,0.08);border:0.5px solid rgba(124,111,255,0.22);border-radius:99px;padding:5px 14px;font-size:11px;font-weight:500;color:var(--ac2);letter-spacing:.05em;text-transform:uppercase;margin-bottom:12px}
.ldot{width:7px;height:7px;border-radius:50%;background:var(--gr);box-shadow:0 0 8px var(--gr);animation:pu 1.5s ease-in-out infinite;flex-shrink:0}
@keyframes pu{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(.75)}}
.hero h1{font-family:var(--fd);font-size:clamp(22px,6vw,42px);font-weight:700;letter-spacing:-.02em;line-height:1.15;margin-bottom:8px}
.grad{background:linear-gradient(135deg,var(--ac),var(--ac2) 45%,var(--pk));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.hero-sub{font-size:13px;color:var(--tx2);max-width:460px;margin:0 auto 10px;line-height:1.7}
.sal-badge{display:inline-flex;align-items:center;gap:6px;background:linear-gradient(135deg,var(--grbg),rgba(124,111,255,0.07));border:0.5px solid var(--grb);border-radius:99px;padding:6px 16px;font-size:13px;font-weight:600;color:var(--gr);margin-bottom:12px}
.hero-meta{display:flex;align-items:center;justify-content:center;gap:10px;flex-wrap:wrap;font-size:11px;color:var(--tx3)}
.hero-meta span{display:flex;align-items:center;gap:4px}

.stats-wrap{padding:0 14px 14px;max-width:920px;margin:0 auto}
.stats{display:grid;grid-template-columns:repeat(5,1fr);gap:6px}
.st{background:var(--bg3);border:0.5px solid var(--b1);border-radius:var(--r);padding:10px 6px;text-align:center}
.st-n{font-family:var(--fd);font-size:20px;font-weight:700;display:block}
.st-l{font-size:9px;color:var(--tx3);text-transform:uppercase;letter-spacing:.05em;display:block;margin-top:2px}

.srcs{display:flex;align-items:center;justify-content:center;gap:5px;padding:0 14px 14px;flex-wrap:wrap}
.src{display:flex;align-items:center;gap:4px;background:var(--bg3);border:0.5px solid var(--b1);border-radius:99px;padding:3px 10px;font-size:10px;font-weight:500;color:var(--tx2)}
.d2{width:5px;height:5px;border-radius:50%;flex-shrink:0}
.si .d2{background:var(--gr)}.sl .d2{background:var(--bl)}.sg .d2{background:var(--ac2)}.sc .d2{background:var(--am)}.sj .d2{background:var(--or)}.se .d2{background:var(--pk)}

.main{max-width:960px;margin:0 auto;padding:0 14px calc(80px + var(--safe-b))}

.prog-bar-wrap{background:var(--bg2);border:0.5px solid var(--grb);border-radius:var(--rl);padding:11px 14px;margin-bottom:10px;display:flex;align-items:center;gap:10px;flex-wrap:wrap}
.prog-label{font-size:10px;text-transform:uppercase;letter-spacing:.06em;color:var(--ac2);font-weight:600;display:flex;align-items:center;gap:5px;white-space:nowrap}
.prog-counts{display:flex;gap:6px;flex-wrap:wrap}
.pc{border-radius:99px;padding:3px 10px;font-size:11px;font-weight:600;white-space:nowrap}
.pc-saved{background:rgba(124,111,255,0.12);border:0.5px solid rgba(124,111,255,0.25);color:var(--ac2)}
.pc-sent{background:var(--grbg);border:0.5px solid var(--grb);color:var(--gr)}

.controls{background:var(--bg2);border:0.5px solid var(--b1);border-radius:var(--rx);padding:12px;margin-bottom:10px;display:flex;flex-direction:column;gap:10px}
.srow{display:flex;gap:7px}
.sw{flex:1;position:relative;min-width:0}
.sw svg{position:absolute;left:11px;top:50%;transform:translateY(-50%);width:14px;height:14px;stroke:var(--tx3);fill:none;stroke-width:2;stroke-linecap:round}
.sw input{width:100%;background:var(--bg3);border:0.5px solid var(--b1);border-radius:var(--r);padding:10px 10px 10px 33px;font-size:14px;color:var(--tx);outline:none;transition:border-color .2s}
.sw input::placeholder{color:var(--tx3)}
.sw input:focus{border-color:var(--ac)}
.ssel{background:var(--bg3);border:0.5px solid var(--b1);border-radius:var(--r);padding:10px 8px;font-size:12px;color:var(--tx2);outline:none;cursor:pointer}
.fsec{display:flex;align-items:center;gap:7px;flex-wrap:wrap}
.flbl{font-size:9px;text-transform:uppercase;letter-spacing:.07em;color:var(--tx3);font-weight:600;white-space:nowrap;min-width:36px}
.chips{display:flex;gap:4px;flex-wrap:wrap}
.chip{font-size:11px;padding:5px 11px;border-radius:99px;border:0.5px solid var(--b1);background:transparent;color:var(--tx3);cursor:pointer;transition:all .15s;white-space:nowrap;min-height:30px;display:flex;align-items:center}
.chip:active{background:var(--bg3)}
.chip.on{background:var(--ac);border-color:var(--ac);color:#fff;font-weight:600;box-shadow:0 0 12px var(--glow)}

.trow{display:flex;align-items:center;gap:8px;margin-bottom:10px}
.rcnt{font-size:11px;color:var(--tx2);white-space:nowrap}
.pw{flex:1;height:2px;background:var(--bg4);border-radius:1px;overflow:hidden}
.pb{height:2px;background:linear-gradient(90deg,var(--ac),var(--pk));border-radius:1px;transition:width .6s linear}
.tinfo{font-size:11px;color:var(--tx3);display:flex;align-items:center;gap:3px;white-space:nowrap}
.rbtn{display:flex;align-items:center;gap:4px;background:var(--bg3);border:0.5px solid var(--b2);border-radius:var(--r);padding:7px 11px;font-size:11px;color:var(--tx2);cursor:pointer;white-space:nowrap;min-height:34px}
.rbtn:active{border-color:var(--ac);color:var(--ac)}

.jgrid{display:flex;flex-direction:column;gap:8px}
.jcard{background:var(--bg2);border:0.5px solid var(--b1);border-radius:var(--rx);padding:14px 14px 12px;transition:all .2s;position:relative;overflow:hidden}
.jcard::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;border-radius:3px 0 0 3px}
.ci::before{background:var(--gr)}.cj::before{background:var(--or)}.cl::before{background:var(--bl)}.cg::before{background:var(--ac2)}.cc::before{background:var(--am)}.ce::before{background:var(--pk)}
.jcard.saved-card{border-color:rgba(124,111,255,0.25);background:rgba(124,111,255,0.03)}
.jcard.sent-card{border-color:rgba(31,209,137,0.2);background:rgba(31,209,137,0.02)}

.jinfo{margin-bottom:10px}
.jtitle{font-family:var(--fd);font-size:14px;font-weight:600;line-height:1.35;margin-bottom:3px}
.jco{font-size:12px;color:var(--tx3);display:flex;align-items:center;gap:4px;margin-bottom:5px}
.jdesc{font-size:11px;color:var(--tx3);line-height:1.55}
.jtags{display:flex;gap:4px;flex-wrap:wrap;margin-bottom:8px}
.tag{font-size:10px;padding:3px 8px;border-radius:99px;font-weight:500;white-space:nowrap}
.ta{background:rgba(124,111,255,.14);color:var(--ac2)}.ts{background:var(--pkbg);color:var(--pk)}.td{background:var(--grbg);color:var(--gr)}.tt{background:var(--blbg);color:var(--bl)}
.tnv{background:var(--bg4);color:var(--tx2)}.tr{background:var(--pkbg);color:var(--pk);font-weight:600}.th{background:rgba(124,111,255,.1);color:var(--ac2)}.tp{background:var(--bg4);color:var(--tx3)}
.tsal{background:var(--grbg);color:var(--gr);font-weight:600}.tnew{background:var(--ac);color:#fff;font-weight:700}.tsent{background:var(--grbg);color:var(--gr);font-weight:600}
.tsi{background:var(--grbg);color:var(--gr)}.tsl{background:var(--blbg);color:var(--bl)}.tsg{background:rgba(124,111,255,.1);color:var(--ac2)}.tsc{background:var(--ambg);color:var(--am)}.tsj{background:var(--orbg);color:var(--or)}.tse{background:var(--pkbg);color:var(--pk)}

.expiry-bar-wrap{width:100%;height:3px;background:var(--bg4);border-radius:2px;margin:6px 0 2px;overflow:hidden}
.expiry-bar{height:3px;border-radius:2px}
.expiry-label{font-size:9px;color:var(--tx3);margin-bottom:8px}

.jbtns{display:grid;grid-template-columns:1fr 1fr 1fr;gap:6px}
.bver,.bemail,.bsave{font-size:11px;padding:9px 6px;border-radius:var(--r);cursor:pointer;transition:all .15s;white-space:nowrap;display:flex;align-items:center;justify-content:center;gap:4px;min-height:38px;font-weight:500;text-decoration:none}
.bver{border:0.5px solid var(--b2);background:transparent;color:var(--tx2)}
.bver:active,.bver:hover{border-color:var(--gr);color:var(--gr);background:var(--grbg)}
.bemail{border:0.5px solid var(--ac);background:rgba(124,111,255,0.1);color:var(--ac2)}
.bemail:active,.bemail:hover{background:var(--ac);color:#fff}
.bsave{border:0.5px solid var(--b1);background:transparent;color:var(--tx3)}
.bsave:active,.bsave:hover,.bsave.saved-on{border-color:var(--am);color:var(--am);background:var(--ambg)}

.jmeta{display:flex;align-items:center;gap:8px;font-size:10px;color:var(--tx3);flex-wrap:wrap;margin-top:10px;padding-top:10px;border-top:0.5px solid var(--b1)}
.jmeta span{display:flex;align-items:center;gap:3px}
.email-chip{font-size:10px;color:var(--ac2);background:rgba(124,111,255,.07);border:0.5px solid rgba(124,111,255,.18);border-radius:99px;padding:2px 7px;display:inline-flex;align-items:center;gap:3px}

.empty{text-align:center;padding:48px 16px;color:var(--tx3)}
.empty p{font-size:15px;color:var(--tx2);margin-top:10px}

/* MODAL */
.mo{position:fixed;inset:0;background:rgba(0,0,0,0.85);backdrop-filter:blur(10px);-webkit-backdrop-filter:blur(10px);z-index:100;display:flex;align-items:flex-end;justify-content:center;opacity:0;pointer-events:none;transition:opacity .22s}
.mo.open{opacity:1;pointer-events:all}
.md{background:var(--bg2);border:0.5px solid var(--b2);border-radius:var(--rx) var(--rx) 0 0;width:100%;max-width:640px;position:relative;max-height:92vh;overflow-y:auto;padding-bottom:var(--safe-b)}
.md::before{content:'';display:block;width:36px;height:4px;background:var(--b3);border-radius:2px;margin:12px auto 0}
.md-head{padding:12px 18px;border-bottom:0.5px solid var(--b1)}
.md-body-wrap{padding:16px 18px 20px}
.md-title{font-family:var(--fd);font-size:17px;font-weight:700;margin-bottom:2px}
.md-sub{font-size:11px;color:var(--tx3)}
.mclose{position:absolute;top:14px;right:14px;background:var(--bg4);border:0.5px solid var(--b1);border-radius:8px;width:30px;height:30px;cursor:pointer;color:var(--tx3);display:flex;align-items:center;justify-content:center;font-size:15px}
.demo-note-box{background:rgba(124,111,255,0.08);border:0.5px solid rgba(124,111,255,0.2);border-radius:var(--r);padding:10px 12px;margin-bottom:12px;font-size:12px;color:var(--ac2);text-align:center}
.dest-box{background:linear-gradient(135deg,var(--grbg),rgba(124,111,255,0.05));border:0.5px solid var(--grb);border-radius:var(--rl);padding:12px 14px;margin-bottom:12px;display:flex;align-items:center;gap:10px}
.dest-icon{width:36px;height:36px;background:var(--grbg);border-radius:var(--r);display:flex;align-items:center;justify-content:center;font-size:17px;flex-shrink:0}
.dest-info{flex:1;min-width:0}
.dest-label{font-size:9px;text-transform:uppercase;letter-spacing:.07em;color:var(--gr);font-weight:600;margin-bottom:2px}
.dest-email{font-size:14px;font-weight:600;color:var(--tx);font-family:var(--fd);word-break:break-all}
.dest-co{font-size:11px;color:var(--tx3);margin-top:1px}
.mf{margin-bottom:11px}
.mf label{font-size:9px;text-transform:uppercase;letter-spacing:.07em;color:var(--tx3);font-weight:600;display:block;margin-bottom:4px}
