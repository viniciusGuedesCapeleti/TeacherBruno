  {id:10,titulo:"Social Media Sênior — Estratégia",empresa:"Marca Premium",area:"social",nivel:"senior",local:"São Paulo, SP",modo:"Híbrido",salario:"R$ 6.000–7.500",salMin:6000,horas:12,fonte:"Emprega Campinas",url:"https://www.empregacampinas.com.br",emailRH:"pessoas@marcapremium.com.br",descricao:"Liderança de estratégia de social media, gestão de equipe e influenciadores."},
  {id:11,titulo:"Analista de TI Pleno — Infraestrutura",empresa:"Tech Solutions",area:"ti",nivel:"pleno",local:"São Paulo, SP",modo:"Híbrido",salario:"R$ 5.500–7.000",salMin:5500,horas:14,fonte:"Jobbol",url:"https://br.jooble.org",emailRH:"rh@techsolutions.com.br",descricao:"Redes, servidores e serviços em nuvem corporativa."},
  {id:12,titulo:"Designer Gráfico Pleno — Branding",empresa:"Studio Criativo",area:"design",nivel:"pleno",local:"São Paulo, SP",modo:"Presencial",salario:"R$ 5.000–6.500",salMin:5000,horas:16,fonte:"Indeed",url:"https://br.indeed.com",emailRH:"vagas@studiocriativo.com.br",descricao:"Branding, identidade visual, campanhas e materiais gráficos."},
];

VAGAS.forEach(v=>{ v.postedAt=AGORA-(v.horas*H); });
let VG=VAGAS.filter(v=>v.salMin>=3500&&v.salMin<=7000&&(AGORA-v.postedAt)<=LIMITE);
let fA="todas",fN="todos",fM="todas",fF="todas",cd=300,vagaAtual=null;
let saved=new Set(),sent=new Set();
try{saved=new Set(JSON.parse(localStorage.getItem("demo_saved")||"[]"));sent=new Set(JSON.parse(localStorage.getItem("demo_sent")||"[]"));}catch(e){}
function saveLS(){try{localStorage.setItem("demo_saved",JSON.stringify([...saved]));localStorage.setItem("demo_sent",JSON.stringify([...sent]));}catch(e){}}
function toggleSave(id){if(saved.has(id))saved.delete(id);else saved.add(id);saveLS();render();}

function setF(tipo,val,el){
  if(tipo==="a")fA=val;else if(tipo==="n")fN=val;else if(tipo==="m")fM=val;else fF=val;
  document.querySelectorAll(`.chip[data-g="${tipo}"]`).forEach(c=>c.classList.remove("on"));
  el.classList.add("on");render();
}
function getFilt(){
  const q=(document.getElementById("srch").value||"").toLowerCase();
  return VG.filter(v=>
    (fA==="todas"||v.area===fA)&&(fN==="todos"||v.nivel===fN)&&
    (fM==="todas"||v.modo===fM)&&(fF==="todas"||v.fonte===fF)&&
    (!q||v.titulo.toLowerCase().includes(q)||v.empresa.toLowerCase().includes(q))
  );
}
function fmtH(p){
  const diff=AGORA-p,min=Math.floor(diff/60000),hr=Math.floor(diff/H),d=Math.floor(diff/(H*24));
  if(min<2)return"agora mesmo";if(min<60)return min+"min atrás";if(hr<24)return hr+"h atrás";if(d===1)return"ontem";return d+"d atrás";
}
const aC={marketing:"ta",social:"ts",design:"td",ti:"tt"};
const aN={marketing:"Marketing",social:"Social",design:"Design",ti:"TI"};
const mC={Remoto:"tr",Híbrido:"th",Presencial:"tp"};
const sC={Indeed:"tsi",LinkedIn:"tsl",Gupy:"tsg",Catho:"tsc",Jobbol:"tsj","Emprega Campinas":"tse"};
const bC={Indeed:"ci",LinkedIn:"cl",Gupy:"cg",Catho:"cc",Jobbol:"cj","Emprega Campinas":"ce"};
function nT(n){return n.charAt(0).toUpperCase()+n.slice(1);}
function pct(v){return Math.max(2,Math.round((1-(AGORA-v.postedAt)/LIMITE)*100));}
function cor(v){return(AGORA-v.postedAt)<(24*H)?'var(--gr)':(AGORA-v.postedAt)<(48*H)?'var(--am)':'var(--pk)';}
function hR(v){return Math.max(1,Math.round((LIMITE-(AGORA-v.postedAt))/H));}

function render(){
  const srt=document.getElementById("srt").value;
  let jobs=getFilt();
  if(srt==="sal")jobs.sort((a,b)=>b.salMin-a.salMin);
  else if(srt==="az")jobs.sort((a,b)=>a.empresa.localeCompare(b.empresa));
  else if(srt==="saved")jobs.sort((a,b)=>(saved.has(b.id)?1:0)-(saved.has(a.id)?1:0));
  else jobs.sort((a,b)=>b.postedAt-a.postedAt);

  document.getElementById("st0").textContent=VG.length;
  document.getElementById("st1").textContent=VG.filter(v=>v.area==="marketing").length;
  document.getElementById("st2").textContent=VG.filter(v=>v.area==="social").length;
  document.getElementById("st3").textContent=VG.filter(v=>v.area==="design").length;
  document.getElementById("st4").textContent=VG.filter(v=>v.area==="ti").length;
  document.getElementById("n-saved").textContent=saved.size;
  document.getElementById("n-sent").textContent=sent.size;
  document.getElementById("fcnt").textContent=jobs.length+" vaga"+(jobs.length!==1?"s":"");
  const now=new Date();
  document.getElementById("ftime").textContent=String(now.getHours()).padStart(2,"0")+":"+String(now.getMinutes()).padStart(2,"0");

  const list=document.getElementById("jlist");
  if(!jobs.length){list.innerHTML=`<div class="empty"><div style="font-size:36px">🔍</div><p style="color:var(--tx2);margin-top:10px">Nenhuma vaga encontrada</p></div>`;return;}

  list.innerHTML=jobs.map(v=>{
    const sv=saved.has(v.id),sn=sent.has(v.id);
    return `<div class="jcard ${bC[v.fonte]||''} ${sv?'saved-card':''} ${sn?'sent-card':''}">
      <div class="jinfo">
        <div class="jtitle">${v.titulo}</div>
        <div class="jco"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>${v.empresa}</div>
        <div class="jdesc">${v.descricao}</div>
      </div>
      <div class="jtags">
        <span class="tag ${aC[v.area]||'ta'}">${aN[v.area]||v.area}</span>
        <span class="tag tnv">${nT(v.nivel)}</span>
        <span class="tag ${mC[v.modo]||'tp'}">${v.modo}</span>
        <span class="tag tsal">💰 ${v.salario}</span>
        ${(AGORA-v.postedAt)<H?'<span class="tag tnew" style="background:var(--gr)">⚡ AGORA</span>':''}
        ${(AGORA-v.postedAt)<(3*H)?'<span class="tag tnew">🔥 NOVA</span>':''}
        ${sn?'<span class="tag tsent">✉ Enviada</span>':''}
        <span class="tag ${sC[v.fonte]||''}">${v.fonte}</span>
      </div>
      <div class="expiry-bar-wrap"><div class="expiry-bar" style="width:${pct(v)}%;background:${cor(v)}"></div></div>
      <div class="expiry-label">Expira em ${hR(v)}h · removida automaticamente após 3 dias</div>
      <div class="jbtns">
        <a class="bver" href="${v.url}" target="_blank" rel="noopener">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>Ver vaga
        </a>
        <button class="bemail" onclick="abrirModal(${v.id})">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>✉ Email
        </button>
        <button class="bsave ${sv?'saved-on':''}" onclick="toggleSave(${v.id})">${sv?'⭐ Salva':'☆ Salvar'}</button>
      </div>
      <div class="jmeta">
        <span><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>${v.local}</span>
        <span><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>${fmtH(v.postedAt)}</span>
        <span class="email-chip"><svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>${v.emailRH}</span>
      </div>
    </div>`;
  }).join("");

  // Re-posiciona tooltip do tour se ativo
  if(tourActive) setTimeout(()=>showStep(currentStep), 300);
}

function abrirModal(id){
  vagaAtual=VG.find(v=>v.id===id);
  if(!vagaAtual)return;
  document.getElementById("md-sub").textContent=`${vagaAtual.titulo} · ${vagaAtual.empresa}`;
  document.getElementById("md-para").textContent=vagaAtual.emailRH;
  document.getElementById("md-co").textContent=`${vagaAtual.empresa} · ${vagaAtual.local} · ${vagaAtual.modo}`;
  document.getElementById("md-assunto").value=`Candidatura — ${vagaAtual.titulo} | Seu Nome`;
  document.getElementById("md-body").value=
`Prezado(a) time de Recrutamento da ${vagaAtual.empresa},

Meu nome é [Seu Nome] e me candidato à vaga de ${vagaAtual.titulo} (${nT(vagaAtual.nivel)}), publicada em ${vagaAtual.fonte}.

[Na versão real, este texto é gerado automaticamente com base na área da vaga, com seu nome, email e cidade já preenchidos.]

Segue currículo em anexo para análise.

Atenciosamente,
[Seu Nome] · seuemail@gmail.com · Campinas, SP`;
  document.getElementById("modal").classList.add("open");
  document.body.style.overflow="hidden";
}
function closeModal(){
  document.getElementById("modal").classList.remove("open");
  document.body.style.overflow="";
  vagaAtual=null;
}
document.getElementById("modal").addEventListener("click",e=>{if(e.target===document.getElementById("modal"))closeModal();});

function showToast(msg){
  const t=document.getElementById("toast");
  document.getElementById("tmsg").textContent=msg;
  t.classList.add("show");
  setTimeout(()=>t.classList.remove("show"),4000);
}
function doRefresh(){
  document.getElementById("ftime").textContent="...";
  cd=300;
  const exp=VG.filter(v=>(Date.now()-v.postedAt)>LIMITE);
  exp.forEach(v=>{const i=VG.findIndex(x=>x.id===v.id);if(i>-1)VG.splice(i,1);});
  setTimeout(()=>{render();showToast(exp.length>0?`🗑️ ${exp.length} vaga(s) expirada(s) removida(s)`:"✅ Atualizado!");},600);
}
document.getElementById("srch").addEventListener("input",render);
document.getElementById("srt").addEventListener("change",render);
setInterval(()=>{
  cd--;
  if(cd<=0){cd=300;doRefresh();}
  const m=Math.floor(cd/60),s=cd%60;
  const el=document.getElementById("cdtxt");if(el)el.textContent=m+":"+(s<10?"0":"")+s;
  const pb=document.getElementById("pbar");if(pb)pb.style.width=Math.round((1-cd/300)*100)+"%";
  const tb=document.getElementById("tbar");if(tb)tb.style.width=Math.round((1-cd/300)*100)+"%";
},1000);

render();
</script>
