<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Bruno Ragazzi – English Teacher</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,600;0,700;1,600;1,700&family=Montserrat:wght@700;800;900&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
:root{
  --red:#CF142B;--red2:#E8192F;
  --blue:#012169;--blue2:#003090;--blue3:#1a3fa8;
  --white:#FFFFFF;--off:#F4F3EF;--dark:#0B0D1A;--gold:#C8A951;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;overflow-x:hidden}
body{font-family:'DM Sans',sans-serif;background:var(--white);color:var(--dark);overflow-x:hidden}

/* ══ UNION JACK LOGO ══ */
.logo-wrap{display:inline-flex;align-items:center;gap:10px;text-decoration:none;flex-shrink:0}
.logo-flag-box{width:52px;height:32px;border-radius:4px;overflow:hidden;flex-shrink:0;box-shadow:0 2px 12px rgba(0,0,0,.5),inset 0 0 0 1px rgba(255,255,255,.15)}
.logo-flag-box svg{width:100%;height:100%;display:block}
.logo-text{display:flex;flex-direction:column;line-height:1}
.logo-name{font-family:'Montserrat',sans-serif;font-weight:900;font-size:1.02rem;letter-spacing:.04em;white-space:nowrap}
.logo-name .r{color:var(--red)}
.logo-sub{font-family:'DM Sans',sans-serif;font-weight:500;font-size:.48rem;letter-spacing:.22em;text-transform:uppercase;margin-top:2px;white-space:nowrap}
.logo-light .logo-name{color:#fff}.logo-light .logo-sub{color:rgba(255,255,255,.42)}
.logo-dark  .logo-name{color:var(--dark)}.logo-dark  .logo-sub{color:rgba(0,0,0,.36)}
.logo-footer .logo-name{color:#fff}.logo-footer .logo-sub{color:rgba(255,255,255,.32)}

/* ══ PROGRESS ══ */
#pb{position:fixed;top:0;left:0;height:3px;background:linear-gradient(90deg,var(--blue),var(--red),var(--gold));z-index:9999;width:0%}

/* ══ WHATSAPP FLOAT ══ */
.wa-float{
  position:fixed;bottom:2rem;right:1.8rem;z-index:8000;
  width:60px;height:60px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  box-shadow:0 4px 20px rgba(0,0,0,.25);
  text-decoration:none;transition:transform .3s,box-shadow .3s;
  animation:waPulse 2.8s ease-in-out infinite;
}
.wa-float:hover{transform:scale(1.1);box-shadow:0 8px 28px rgba(37,211,102,.55)}
.wa-float svg{width:60px;height:60px;display:block}
@keyframes waPulse{
  0%,100%{box-shadow:0 4px 20px rgba(0,0,0,.25)}
  50%{box-shadow:0 4px 20px rgba(0,0,0,.25),0 0 0 8px rgba(37,211,102,.18)}
}

/* ══ NAV ══ */
nav{position:fixed;top:0;left:0;right:0;z-index:1000;padding:1rem 3rem;display:flex;justify-content:space-between;align-items:center;transition:all .4s}
nav.solid{background:rgba(255,255,255,.97);backdrop-filter:blur(20px);box-shadow:0 1px 0 rgba(0,0,0,.08)}
#logo-l{display:inline-flex}#logo-d{display:none}
nav.solid #logo-l{display:none}nav.solid #logo-d{display:inline-flex}
.nav-links{display:flex;gap:2rem;list-style:none;align-items:center}
.nav-links a{color:rgba(255,255,255,.78);text-decoration:none;font-size:.78rem;font-weight:600;letter-spacing:.08em;text-transform:uppercase;transition:color .2s}
nav.solid .nav-links a{color:rgba(0,0,0,.52)}
.nav-links a:hover{color:var(--red)!important}
.nav-cta-btn{background:var(--red)!important;color:#fff!important;padding:.5rem 1.3rem;border-radius:50px;font-size:.76rem!important;border:2px solid var(--red);transition:all .25s!important}
.nav-cta-btn:hover{background:transparent!important;color:var(--red)!important}

/* ══ HERO – Union Jack BG ══ */
.hero{min-height:100vh;position:relative;overflow:hidden;display:flex;align-items:center;padding-top:72px}
/* Full Union Jack as hero background */
.hero-uj-bg{position:absolute;inset:0;z-index:0}
.hero-uj-bg svg{width:100%;height:100%;display:block;opacity:.9}
/* dark overlay for readability */
.hero-overlay{position:absolute;inset:0;z-index:1;background:linear-gradient(135deg,rgba(1,33,105,.82) 0%,rgba(1,33,105,.75) 40%,rgba(1,33,105,.4) 100%)}
.hero-white-cut{position:absolute;top:0;right:0;bottom:0;width:46%;background:var(--white);clip-path:polygon(18% 0,100% 0,100% 100%,0% 100%);z-index:2}
.hero-inner{position:relative;z-index:5;width:100%;max-width:1280px;margin:0 auto;padding:2rem 3rem;display:grid;grid-template-columns:1.1fr 1fr;gap:4rem;align-items:center}
.flag-ribbon{display:inline-flex;align-items:center;gap:.6rem;background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.22);color:rgba(255,255,255,.9);font-size:.66rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;padding:.38rem 1rem;border-radius:50px;margin-bottom:1.5rem;animation:fadeUp .6s ease both}
.flag-ribbon .dot{width:6px;height:6px;border-radius:50%;background:var(--red);flex-shrink:0}
.hero-copy h1{font-family:'Cormorant Garamond',Georgia,serif;font-weight:700;font-size:clamp(3.2rem,6.8vw,6.2rem);line-height:1.01;color:#fff;letter-spacing:-.01em;animation:fadeUp .7s .1s ease both}
.hero-copy h1 .outline{-webkit-text-stroke:1.5px rgba(255,255,255,.65);color:transparent;font-style:italic}
.hero-copy h1 .red-word{color:var(--red)}
.hero-copy .sub{font-size:.95rem;color:rgba(255,255,255,.65);margin:1.2rem 0 2rem;line-height:1.78;max-width:420px;animation:fadeUp .7s .2s ease both}
.cta-group{display:flex;gap:.9rem;flex-wrap:wrap;animation:fadeUp .7s .3s ease both}
.btn-hero{display:inline-flex;align-items:center;gap:.45rem;padding:.9rem 2rem;border-radius:50px;font-weight:700;font-size:.88rem;text-decoration:none;transition:all .3s;letter-spacing:.02em;cursor:pointer;border:none;font-family:'DM Sans',sans-serif}
.btn-hero.primary{background:var(--red);color:#fff}
.btn-hero.primary:hover{transform:translateY(-3px);box-shadow:0 12px 36px rgba(207,20,43,.5);background:var(--red2)}
.btn-hero.ghost{border:2px solid rgba(255,255,255,.4);color:#fff;background:transparent}
.btn-hero.ghost:hover{border-color:#fff;background:rgba(255,255,255,.12);transform:translateY(-3px)}
.proof-bar{display:flex;align-items:center;gap:1rem;margin-top:2.2rem;animation:fadeUp .7s .4s ease both;flex-wrap:wrap}
.proof-avatars{display:flex;flex-shrink:0}
.proof-avatars span{width:32px;height:32px;border-radius:50%;border:2px solid rgba(255,255,255,.3);background:linear-gradient(135deg,rgba(255,255,255,.22),rgba(255,255,255,.06));display:flex;align-items:center;justify-content:center;font-size:.7rem;color:#fff;margin-left:-7px;font-weight:700}
.proof-avatars span:first-child{margin-left:0}
.proof-text{color:rgba(255,255,255,.6);font-size:.76rem;line-height:1.4}
.proof-text strong{color:#fff}
.stars-row{color:var(--gold);font-size:.68rem;letter-spacing:.04em}
/* UK icons row in hero */
.uk-icons-row{display:flex;gap:1rem;margin-top:1.8rem;flex-wrap:wrap;animation:fadeUp .7s .5s ease both}
.uk-icon-chip{display:flex;align-items:center;gap:.4rem;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.18);border-radius:50px;padding:.3rem .75rem;font-size:.72rem;color:rgba(255,255,255,.8)}

/* hero panel */
.hero-panel{background:#fff;border-radius:1.8rem;padding:2.2rem;box-shadow:0 32px 80px rgba(0,0,0,.24);position:relative;overflow:hidden;animation:fadeUp .8s .15s ease both}
.hero-panel::before{content:'';position:absolute;top:0;left:0;right:0;height:4px;background:linear-gradient(90deg,var(--blue),var(--red),var(--gold))}
.panel-tag{display:inline-block;background:rgba(207,20,43,.08);color:var(--red);font-size:.63rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:.28rem .75rem;border-radius:50px;margin-bottom:1rem}
.panel-title{font-family:'Cormorant Garamond',serif;font-weight:700;font-size:1.8rem;color:var(--dark);margin-bottom:.25rem}
.panel-sub{font-size:.77rem;color:#999;margin-bottom:1.4rem;line-height:1.55}
.form-f{display:flex;flex-direction:column;gap:.72rem}
.form-f input,.form-f select{padding:.78rem 1rem;border:2px solid #EAEAEA;border-radius:.7rem;font-family:'DM Sans',sans-serif;font-size:.86rem;color:var(--dark);background:#FAFAFA;transition:border-color .2s;outline:none;width:100%}
.form-f input:focus,.form-f select:focus{border-color:var(--red);background:#fff}
.form-f input::placeholder{color:#bbb}
.submit-btn{width:100%;padding:.95rem;background:var(--red);color:#fff;border:none;border-radius:.7rem;font-family:'Montserrat',sans-serif;font-weight:800;font-size:.95rem;letter-spacing:.04em;cursor:pointer;transition:all .3s}
.submit-btn:hover{background:var(--blue);transform:translateY(-2px);box-shadow:0 10px 30px rgba(1,33,105,.4)}
.form-note{text-align:center;font-size:.68rem;color:#aaa;margin-top:.25rem}
.f-badges{display:flex;gap:.5rem;justify-content:center;margin-top:.9rem;flex-wrap:wrap}
.f-b{display:flex;align-items:center;gap:.3rem;background:#F2F2F2;border-radius:50px;padding:.28rem .65rem;font-size:.65rem;color:#555;font-weight:600}

/* ══ TICKER ══ */
.ticker-wrap{background:var(--red);padding:.65rem 0;overflow:hidden;position:relative;z-index:10}
.ticker-track{display:flex;width:max-content;animation:ticker 28s linear infinite}
.ticker-item{white-space:nowrap;color:#fff;font-size:.74rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:0 2rem;border-right:1px solid rgba(255,255,255,.3)}
@keyframes ticker{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* ══ SECTION UTILS ══ */
.container{max-width:1200px;margin:0 auto;padding:0 2rem}
.section-kicker{font-size:.67rem;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:var(--red);margin-bottom:.8rem;display:flex;align-items:center;gap:.6rem}
.section-kicker::before{content:'';display:inline-block;width:18px;height:2px;background:var(--red);flex-shrink:0}
.section-h{font-family:'Cormorant Garamond',serif;font-weight:700;font-size:clamp(2.1rem,3.9vw,3.5rem);line-height:1.06;color:var(--dark);margin-bottom:1.1rem}
.section-h.light{color:#fff}
.section-p{font-size:.93rem;color:#666;line-height:1.85;max-width:460px}
.reveal{opacity:0;transform:translateY(22px);transition:opacity .6s,transform .6s}
.reveal.visible{opacity:1;transform:translateY(0)}

/* ══ WHY – Union Jack BG ══ */
.why{padding:7rem 2rem;position:relative;overflow:hidden}
.why-uj-bg{position:absolute;inset:0;z-index:0}
.why-uj-bg svg{width:100%;height:100%;display:block;opacity:.85}
.why-overlay{position:absolute;inset:0;z-index:1;background:linear-gradient(135deg,rgba(1,33,105,.9) 0%,rgba(1,33,105,.85) 100%)}
.why-inner{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:center;position:relative;z-index:2}
.feat-list{display:flex;flex-direction:column;gap:1rem;margin-top:1.8rem}
.feat{display:flex;gap:1.1rem;align-items:flex-start;padding:1.4rem;border-radius:1.2rem;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.14);transition:all .3s;opacity:0;transform:translateY(20px)}
.feat.visible{opacity:1;transform:translateY(0)}
.feat:hover{background:rgba(255,255,255,.14);border-color:rgba(207,20,43,.5);transform:translateX(5px)}
.feat-ico{width:44px;height:44px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.2rem;flex-shrink:0}
.feat-ico.blue{background:rgba(255,255,255,.15)}.feat-ico.red{background:rgba(207,20,43,.3)}.feat-ico.gold{background:rgba(200,169,81,.25)}
.feat h4{font-family:'Montserrat',sans-serif;font-weight:800;font-size:.88rem;color:#fff;margin-bottom:.22rem}
.feat p{font-size:.8rem;color:rgba(255,255,255,.55);line-height:1.6}
.big-quote{background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.15);border-radius:1.8rem;padding:2.8rem;position:relative;overflow:hidden;opacity:0;transform:translateX(30px);transition:opacity .7s,transform .7s}
.big-quote.visible{opacity:1;transform:translateX(0)}
.big-quote::before{content:'"';font-family:'Cormorant Garamond',serif;font-size:10rem;color:rgba(255,255,255,.07);position:absolute;top:-2rem;left:1rem;line-height:1;pointer-events:none}
.big-quote::after{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--red),var(--gold))}
.big-quote blockquote{font-family:'Cormorant Garamond',serif;font-weight:600;font-size:1.1rem;color:rgba(255,255,255,.9);line-height:1.78;font-style:italic;position:relative;z-index:1;margin-bottom:1.4rem}
.quote-sig{display:flex;align-items:center;gap:1rem}
.q-av{width:48px;height:48px;border-radius:50%;background:linear-gradient(135deg,var(--red),var(--gold));display:flex;align-items:center;justify-content:center;font-family:'Montserrat',sans-serif;font-weight:900;font-size:1rem;color:#fff;flex-shrink:0}
.q-name{color:#fff;font-family:'Montserrat',sans-serif;font-weight:800;font-size:.88rem}
.q-role{color:rgba(255,255,255,.45);font-size:.74rem}
.uk-bar{margin-top:1.8rem;height:6px;border-radius:50px;background:linear-gradient(90deg,var(--red) 0%,var(--red) 33%,#fff 33%,#fff 40%,var(--blue2) 40%,var(--blue2) 60%,#fff 60%,#fff 67%,var(--red) 67%,var(--red) 100%);opacity:.7}

/* ══ JOURNEY ══ */
.journey{padding:7rem 2rem;background:var(--off);position:relative;overflow:hidden}
/* subtle UK icon watermarks */
.journey-watermark{position:absolute;right:-40px;top:50%;transform:translateY(-50%);font-size:200px;opacity:.03;pointer-events:none;line-height:1}
.journey-inner{max-width:860px;margin:0 auto;position:relative;z-index:1}
.journey-header{text-align:center;margin-bottom:4.5rem}
.steps{display:flex;flex-direction:column;position:relative}
.steps::before{content:'';position:absolute;left:42px;top:0;bottom:0;width:2px;background:linear-gradient(180deg,var(--blue),var(--red),var(--gold));border-radius:2px}
.step{display:flex;gap:1.5rem;align-items:flex-start;padding:1.5rem 1.5rem 1.5rem 1.8rem;margin-bottom:.8rem;background:#fff;border-radius:1.2rem;border:1px solid rgba(0,0,0,.07);box-shadow:0 2px 12px rgba(0,0,0,.05);opacity:0;transform:translateX(-25px);transition:opacity .5s,transform .5s}
.step.visible{opacity:1;transform:translateX(0)}
.step:hover{box-shadow:0 8px 28px rgba(1,33,105,.1);border-color:rgba(1,33,105,.15);transform:translateX(4px)!important}
.step-num{width:52px;height:52px;border-radius:50%;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-family:'Montserrat',sans-serif;font-weight:900;font-size:1.15rem;color:#fff;position:relative;z-index:2;box-shadow:0 0 0 4px var(--off)}
.step-body{flex:1;padding-top:.4rem;min-width:0}
.step-label{font-size:.62rem;font-weight:700;letter-spacing:.14em;text-transform:uppercase;margin-bottom:.35rem}
.step-body h3{font-family:'Cormorant Garamond',serif;font-weight:700;font-size:1.45rem;color:var(--dark);margin-bottom:.3rem}
.step-body p{font-size:.86rem;color:#777;line-height:1.75}
.sn1{background:var(--blue)}.sn2{background:#5a1a8c}.sn3{background:var(--red)}.sn4{background:#b87a10}.sn5{background:#1a7a4e}.sn6{background:var(--blue2)}
.sl1{color:var(--blue)}.sl2{color:#5a1a8c}.sl3{color:var(--red)}.sl4{color:#b87a10}.sl5{color:#1a7a4e}.sl6{color:var(--blue2)}
.step-cta{background:linear-gradient(135deg,var(--blue),var(--red));border-radius:1.5rem;padding:2.5rem 2rem;text-align:center;margin-top:1rem;opacity:0;transform:translateY(25px);transition:opacity .6s,transform .6s}
.step-cta.visible{opacity:1;transform:translateY(0)}
.step-cta h3{font-family:'Cormorant Garamond',serif;font-weight:700;font-size:2.2rem;color:#fff;margin-bottom:.5rem}
.step-cta p{color:rgba(255,255,255,.7);font-size:.86rem;margin-bottom:1.4rem}

/* ══ COURSES ══ */
.courses{padding:7rem 2rem;background:var(--white);position:relative;overflow:hidden}
.courses-uj-strip{position:absolute;top:0;left:0;right:0;height:6px;background:linear-gradient(90deg,var(--blue) 0%,var(--blue) 33%,var(--white) 33%,var(--white) 40%,var(--red) 40%,var(--red) 60%,var(--white) 60%,var(--white) 67%,var(--blue) 67%,var(--blue) 100%)}
.bento{display:grid;grid-template-columns:repeat(4,1fr);gap:1.2rem;margin-top:3rem}
.bento-card{border-radius:1.5rem;padding:1.8rem;transition:all .3s;position:relative;overflow:hidden;opacity:0;transform:translateY(18px)}
.bento-card.visible{opacity:1;transform:translateY(0)}
.bento-card:hover{transform:translateY(-6px)!important;box-shadow:0 22px 50px rgba(0,0,0,.13)}
.bento-card.span2{grid-column:span 2}
.bento-card.white-card{background:#fff;border:1px solid rgba(0,0,0,.07)}
.bento-card.white-card::after{content:'';position:absolute;bottom:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--blue),var(--red));transform:scaleX(0);transform-origin:left;transition:transform .3s}
.bento-card.white-card:hover::after{transform:scaleX(1)}
.bento-card.white-card:hover{border-color:rgba(207,20,43,.2)}
.bento-card.blue-card{background:linear-gradient(135deg,var(--blue),var(--blue3))}
.bento-card.red-card{background:linear-gradient(135deg,var(--red),#8B0F1F)}
.bento-card.navy-card{background:linear-gradient(135deg,#0B0D1A,#1a1f44)}
.bento-card.gold-card{background:linear-gradient(135deg,#8B6914,var(--gold))}
.bento-ico{font-size:2.2rem;margin-bottom:1rem;display:block}
.bento-card h3{font-family:'Montserrat',sans-serif;font-weight:800;font-size:1.05rem;color:var(--dark);margin-bottom:.4rem}
.bento-card.blue-card h3,.bento-card.red-card h3,.bento-card.navy-card h3,.bento-card.gold-card h3{color:#fff}
.bento-card p{font-size:.8rem;color:#888;line-height:1.65}
.bento-card.blue-card p,.bento-card.red-card p,.bento-card.navy-card p,.bento-card.gold-card p{color:rgba(255,255,255,.72)}
.bento-tag{display:inline-block;font-size:.57rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:.2rem .65rem;border-radius:50px;margin-bottom:.7rem;background:rgba(207,20,43,.09);color:var(--red)}
.bento-card.blue-card .bento-tag,.bento-card.navy-card .bento-tag{background:rgba(255,255,255,.18);color:#fff}
.bento-card.red-card .bento-tag,.bento-card.gold-card .bento-tag{background:rgba(255,255,255,.22);color:#fff}

/* ══ UK ICONS SHOWCASE ══ */
.uk-showcase{padding:5rem 2rem;background:var(--off);overflow:hidden;position:relative}
.uk-showcase::before,.uk-showcase::after{content:'';position:absolute;left:0;right:0;height:4px}
.uk-showcase::before{top:0;background:linear-gradient(90deg,var(--red),var(--white),var(--blue))}
.uk-showcase::after{bottom:0;background:linear-gradient(90deg,var(--blue),var(--white),var(--red))}
.uk-icons-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:1.5rem;margin-top:3rem}
.uk-icon-card{background:#fff;border-radius:1.4rem;padding:2rem 1rem;text-align:center;border:1px solid rgba(0,0,0,.07);transition:all .3s;opacity:0;transform:translateY(20px);cursor:default}
.uk-icon-card.visible{opacity:1;transform:translateY(0)}
.uk-icon-card:hover{transform:translateY(-6px)!important;box-shadow:0 16px 40px rgba(1,33,105,.12);border-color:rgba(1,33,105,.2)}
.uk-icon-card .icon-svg{width:60px;height:60px;margin:0 auto 1rem;display:block}
.uk-icon-card h4{font-family:'Montserrat',sans-serif;font-weight:800;font-size:.8rem;color:var(--dark);margin-bottom:.3rem}
.uk-icon-card p{font-size:.72rem;color:#999;line-height:1.5}

/* ══ TESTIMONIALS – Union Jack BG ══ */
.testimonials{padding:7rem 2rem;position:relative;overflow:hidden}
.testi-uj-bg{position:absolute;inset:0;z-index:0}
.testi-uj-bg svg{width:100%;height:100%;display:block;opacity:.85}
.testi-overlay{position:absolute;inset:0;z-index:1;background:linear-gradient(160deg,rgba(1,33,105,.92) 0%,rgba(1,33,105,.88) 100%)}
.testimonials .container{position:relative;z-index:2}
.testi-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.4rem;margin-top:3.5rem}
.testi-card{border-radius:1.4rem;padding:1.8rem;position:relative;overflow:hidden;opacity:0;transform:translateY(22px);transition:opacity .55s,transform .55s,box-shadow .3s;border:none;background:#fff}
.testi-card.visible{opacity:1;transform:translateY(0)}
.testi-card:hover{box-shadow:0 16px 44px rgba(0,0,0,.15);transform:translateY(-5px)!important}
.testi-card::before{content:'"';font-family:'Cormorant Garamond',serif;font-size:6rem;line-height:1;color:rgba(207,20,43,.1);position:absolute;top:-.6rem;left:1rem;pointer-events:none}
