let lang='de';
function setLang(l){
  lang=l;
  document.querySelectorAll('.lbtn').forEach(b=>b.classList.toggle('active',b.textContent.toLowerCase()===l));
  const d=T[l];
  document.querySelectorAll('[data-t]').forEach(el=>{
    const k=el.dataset.t;if(d[k]===undefined)return;
    if(k==='proof'){el.innerHTML=d[k];return}
    if(['wy_h','j_h','ct_h','ts_h'].includes(k)){el.innerHTML=d[k];return}
    el.textContent=d[k];
  });
  document.querySelectorAll('[data-ph]').forEach(el=>{const k=el.dataset.ph;if(d[k])el.placeholder=d[k]});
  buildTicker(d.ticker_items);
}
function buildTicker(items){
  const t=document.getElementById('ticker');
  const h=items.map(i=>`<div class="ticker-item">✦ ${i}</div>`).join('');
  t.innerHTML=h+h;
}
buildTicker(T.de.ticker_items);
const nav2=document.getElementById('nav');
window.addEventListener('scroll',()=>{
  nav2.classList.toggle('solid',window.scrollY>50);
  document.getElementById('pb').style.width=(window.scrollY/(document.documentElement.scrollHeight-window.innerHeight)*100)+'%';
},{passive:true});
const io=new IntersectionObserver(entries=>{
  entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('visible');io.unobserve(e.target)}});
},{threshold:.1});
document.querySelectorAll('.reveal,.feat,.step,.bento-card,.ci2,.cform2,.big-quote,.step-cta,.testi-card,.uk-icon-card').forEach(el=>io.observe(el));
function showNotif(){
  const n=document.getElementById('notif');
  document.getElementById('ntxt').textContent=T[lang].notif_ok;
  n.classList.add('show');setTimeout(()=>n.classList.remove('show'),4500);
}
function heroSubmit(){
  if(!document.getElementById('h_name').value||!document.getElementById('h_email').value)return;
  showNotif();['h_name','h_email','h_phone'].forEach(id=>document.getElementById(id).value='');document.getElementById('h_course').selectedIndex=0;
}
function ctaSubmit(){
  if(!document.getElementById('cn').value||!document.getElementById('ce').value)return;
  showNotif();['cn','ce','cm'].forEach(id=>document.getElementById(id).value='');document.getElementById('cc').selectedIndex=0;
}
